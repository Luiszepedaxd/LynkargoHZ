{
  "version": 2,
  "builds": [
    {
      "src": "*.htm",
      "use": "@vercel/static"
    },
    {
      "src": "*.jpg",
      "use": "@vercel/static"
    },
    {
      "src": "*.png",
      "use": "@vercel/static"
    },
    {
      "src": "*.gif",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.htm"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
