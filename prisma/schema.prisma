// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Modelo para usuarios autenticados
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  nombre    String
  empresa   String?
  tipo      UserType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  profile   UserProfile?
  orders    Order[]
  reviews   Review[]
  notifications Notification[]

  @@map("users")
}

// Perfil extendido del usuario
model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  telefono        String?
  direccion       String?
  ciudad          String?
  estado          String?
  codigoPostal    String?
  rfc             String?
  website         String?
  descripcion     String?
  logo            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// Newsletter subscribers
model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  nombre    String?
  empresa   String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("newsletter_subscribers")
}

// Proveedores de servicios logísticos
model Provider {
  id          String   @id @default(cuid())
  userId      String   @unique
  nombre      String
  descripcion String?
  servicios   Service[]
  ubicaciones Location[]
  documentos  Document[]
  calificacion Float   @default(0)
  totalReviews Int    @default(0)
  activo      Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]
  reviews   Review[]

  @@map("providers")
}

// Servicios ofrecidos por proveedores
model Service {
  id          String   @id @default(cuid())
  providerId  String
  nombre      String
  descripcion String?
  precio      Float?
  unidad      String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("services")
}

// Ubicaciones de los proveedores
model Location {
  id         String   @id @default(cuid())
  providerId String
  ciudad     String
  estado     String
  pais       String   @default("México")
  activo     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relaciones
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("locations")
}

// Documentos de los proveedores
model Document {
  id         String   @id @default(cuid())
  providerId String
  tipo       DocumentType
  nombre     String
  url        String
  activo     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relaciones
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("documents")
}

// Órdenes de servicio
model Order {
  id          String      @id @default(cuid())
  userId      String
  providerId  String?
  servicio    String
  descripcion String?
  origen      String
  destino     String
  peso        Float?
  volumen     Float?
  estado      OrderStatus @default(PENDIENTE)
  precio      Float?
  fechaEnvio  DateTime?
  fechaEntrega DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relaciones
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider Provider? @relation(fields: [providerId], references: [id])

  @@map("orders")
}

// Reviews y calificaciones
model Review {
  id         String   @id @default(cuid())
  userId     String
  providerId String
  orderId    String?
  calificacion Int
  comentario String?
  activo     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relaciones
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

// Notificaciones del sistema
model Notification {
  id        String   @id @default(cuid())
  userId    String
  tipo      NotificationType
  titulo    String
  mensaje   String
  datos     Json?
  leida     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// Enums
enum UserType {
  CLIENTE
  PROVEEDOR
  ADMIN
}

enum OrderStatus {
  PENDIENTE
  ACEPTADA
  EN_PROCESO
  EN_TRANSITO
  ENTREGADA
  CANCELADA
}

enum DocumentType {
  RFC
  ACTA_CONSTITUTIVA
  COMPROBANTE_DOMICILIO
  SEGURO
  LICENCIA
  OTRO
}

enum NotificationType {
  ORDEN
  ESTADO
  SISTEMA
  PROMOCION
}
