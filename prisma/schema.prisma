generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== MODELO DE USUARIOS (Persona física) =====

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  nombre    String
  telefono  String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  profile         UserProfile?
  memberships     OrganizationMember[]
  orders          Order[]
  notifications   Notification[]
  userRoles       UserRole[]
  contexts        UserContext[]

  @@map("users")
}

model UserProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  direccion String?
  ciudad    String?
  estado    String?
  codigoPostal String?
  website   String?
  descripcion String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// ===== MODELO DE ORGANIZACIONES =====

model Organization {
  id        String            @id @default(uuid())
  nombre    String
  tipo      OrganizationType
  activo    Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  // Relaciones
  profile   OrganizationProfile?
  members   OrganizationMember[]
  providers Provider[]
  orders    Order[]
  contexts  UserContext[]

  @@map("organizations")
}

model OrganizationProfile {
  id             String       @id @default(uuid())
  organizationId String       @unique
  rfc            String?
  direccion      String?
  ciudad         String?
  estado         String?
  codigoPostal   String?
  website        String?
  descripcion    String?
  logo           String?
  telefono       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relaciones
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_profiles")
}

model OrganizationMember {
  id             String      @id @default(uuid())
  organizationId String
  userId         String
  role           MemberRole
  activo         Boolean     @default(true)
  joinedAt       DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relaciones
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

// ===== MODELO DE ROLES DE PLATAFORMA =====

model UserRole {
  id        String      @id @default(uuid())
  userId    String
  role      PlatformRole
  activo    Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Relaciones
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

// ===== MODELO DE CONTEXTO ACTIVO =====

model UserContext {
  id             String   @id @default(uuid())
  userId         String   @unique
  activeRole     PlatformRole
  activeOrganizationId String?
  lastSwitchedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relaciones
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [activeOrganizationId], references: [id], onDelete: SetNull)

  @@map("user_contexts")
}

// ===== MODELO DE PROVEEDORES =====

model Provider {
  id             String                @id @default(uuid())
  organizationId String
  nombre         String
  descripcion    String?
  activo         Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  // Relaciones
  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  services     ProviderService[]
  locations    ProviderLocation[]
  documents    ProviderDocument[]
  orders       Order[]

  @@map("providers")
}

model ProviderService {
  id          String   @id @default(uuid())
  providerId  String
  nombre      String
  descripcion String?
  precio      Float?
  unidad      String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_services")
}

model ProviderLocation {
  id         String   @id @default(uuid())
  providerId String
  ciudad     String
  estado     String
  pais       String   @default("Mexico")
  activo     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relaciones
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_locations")
}

model ProviderDocument {
  id         String       @id @default(uuid())
  providerId String
  tipo       DocumentType
  nombre     String
  url        String
  verificado Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  // Relaciones
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_documents")
}

// ===== MODELO DE ÓRDENES =====

model Order {
  id             String      @id @default(uuid())
  userId         String
  organizationId String?
  providerId     String?
  servicio       String
  descripcion    String?
  origen         String
  destino        String
  peso           Float?
  volumen        Float?
  precio         Float?
  estado         OrderStatus @default(PENDIENTE)
  fechaEnvio     DateTime?
  fechaEntrega   DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relaciones
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  provider     Provider?     @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@map("orders")
}

// ===== MODELO DE NOTIFICACIONES =====

model Notification {
  id          String            @id @default(uuid())
  userId      String
  titulo      String
  mensaje     String
  tipo        NotificationType
  leida       Boolean           @default(false)
  accionUrl   String?
  accionTexto String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relaciones
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ===== MODELO DE NEWSLETTER =====

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  nombre    String?
  empresa   String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("newsletter_subscribers")
}

// ===== ENUMS =====

enum OrganizationType {
  CLIENTE
  PROVEEDOR
  MIXTO
}

enum MemberRole {
  OWNER
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

enum PlatformRole {
  CLIENTE
  PROVEEDOR
  ADMIN
}

enum OrderStatus {
  PENDIENTE
  CONFIRMADA
  EN_PROCESO
  EN_TRANSITO
  ENTREGADA
  CANCELADA
}

enum DocumentType {
  RFC
  ACTA_CONSTITUTIVA
  COMPROBANTE_DOMICILIO
  SEGURO
  LICENCIA
  OTRO
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  INVITATION
  ROLE_CHANGE
  ORDER_UPDATE
}